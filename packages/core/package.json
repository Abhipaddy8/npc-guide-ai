{
  "name": "@npc-guide/core",
  "version": "0.1.0",
  "description": "Your repo remembers everything. Silent mission system for AI coding agents.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "npc-guide": "dist/hooks/init.js"
  },
  "exports": {
    ".": {
