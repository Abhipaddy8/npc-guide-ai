{
  "name": "npc-guide",
  "version": "0.1.0",
  "description": "Your repo remembers everything. Silent mission system for AI coding agents.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "npc-guide": "dist/hooks/init.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "postinstall": "node dist/installer/index.js || true",
    "prepublishOnly": "npm run build",
    "test": "node --test dist/**/*.test.js"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "claude",
    "cursor",
    "copilot",
    "mission-system",
    "memory",
    "context",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/equipp/npc-guide-ai"
  },
  "author": "Abhishek Padmanabhan",
  "license": "MIT",
  "dependencies": {
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
