    "dev": "tsc --watch",
    "postinstall": "node dist/installer/index.js || true",
    "test": "node --test dist/**/*.test.js"
  },
  "dependencies": {
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
